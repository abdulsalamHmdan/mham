<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <%- include('partials/head') %>
  <script src="/socket.io/socket.io.js" defer></script>
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar') %>

    <main class="main">
      <header class="page-header">
        <div>
          <h1 class="page-title">قسم <%= departmentLabel %></h1>
          <p class="page-sub">متابعة أسبوعية <%= weekLabel %> — مرحباً <%= user.name %></p>
        </div>
        <span class="dept-badge dept-<%= department %>"><%= departmentLabel %></span>
      </header>

      <% if (success) { %>
        <div class="alert alert-success">تم حفظ البيانات بنجاح.</div>
      <% } %>
      <% if (outsideWeek) { %>
        <div class="alert alert-error">لا يمكن حفظ إدخال خارج الأسبوع الحالي.</div>
      <% } %>

      <section class="panel">
        <div class="panel-head">
          <h3><%= department === 'financial' && financialEntry ? 'تعديل بيانات الأسبوع' : 'تعبئة البيانات' %></h3>
          <span class="muted"><%= department === 'financial' ? 'يتم حفظ سجل واحد فقط لكل أسبوع' : 'جميع الحقول الرقمية تقبل أرقاماً صحيحة فقط' %></span>
        </div>
        <div class="panel-body">
          <form method="POST" action="/employee/submit" class="form-grid" enctype="<%= department === 'media' ? 'multipart/form-data' : 'application/x-www-form-urlencoded' %>">

            <% if (department === 'financial') { %>
              <label class="field">
                <span>كبار الداعمين (ر.س)</span>
                <input type="number" name="majorDonors" min="0" step="1" placeholder="0" value="<%= financialEntry ? financialEntry.majorDonors || 0 : '' %>" required>
              </label>
              <label class="field">
                <span>كشك التبرعات (ر.س)</span>
                <input type="number" name="donationKiosk" min="0" step="1" placeholder="0" value="<%= financialEntry ? financialEntry.donationKiosk || 0 : '' %>" required>
              </label>
              <label class="field">
                <span>الجهات المانحة (ر.س)</span>
                <input type="number" name="grantOrganizations" min="0" step="1" placeholder="0" value="<%= financialEntry ? financialEntry.grantOrganizations || 0 : '' %>" required>
              </label>
              <label class="field">
                <span>الدعم الحكومي (ر.س)</span>
                <input type="number" name="governmentSupport" min="0" step="1" placeholder="0" value="<%= financialEntry ? financialEntry.governmentSupport || 0 : '' %>" required>
              </label>
              <label class="field">
                <span>ديسق (من API)</span>
                <input type="number" value="<%= disqRevenue %>" readonly>
              </label>
            <% } else if (department === 'media') { %>
              <label class="field field-full">
                <span>ملف التصميم</span>
                <input type="file" name="image" accept="image/*" required>
              </label>
              <label class="field">
                <span>عنوان التصميم</span>
                <input type="text" name="title" placeholder="مثال: حملة شهر رمضان" required>
              </label>
            <% } else if (department === 'content') { %>
              <label class="field">
                <span>عدد المنشورات</span>
                <input type="number" name="count" min="0" step="1" placeholder="0" required>
              </label>
              <label class="field">
                <span>المنصة (اختياري)</span>
                <input type="text" name="platform" placeholder="مثال: تويتر، إنستجرام">
              </label>
            <% } else if (department === 'followup') { %>
              <label class="field">
                <span>زيارات من الجمعية لجهة خارجية</span>
                <input type="number" name="associationToExternal" min="0" step="1" placeholder="0" required>
              </label>
              <label class="field">
                <span>زيارات من جهة خارجية للجمعية</span>
                <input type="number" name="externalToAssociation" min="0" step="1" placeholder="0" required>
              </label>
              <label class="field">
                <span>زيارات الموقع الإلكتروني</span>
                <input type="number" name="websiteVisits" min="0" step="1" placeholder="0" required>
              </label>
            <% } %>

            <% if (department !== 'financial') { %>
              <label class="field">
                <span>التاريخ</span>
                <input type="date" name="date" min="<%= weekStartInput %>" max="<%= weekEndInput %>" value="<%= todayInput %>">
              </label>
            <% } %>
            <label class="field field-full">
              <span>ملاحظات (اختياري)</span>
              <textarea name="note" rows="2" placeholder="أي ملاحظات إضافية"><%= financialEntry ? financialEntry.note || '' : '' %></textarea>
            </label>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary"><%= department === 'financial' && financialEntry ? 'حفظ التعديل' : 'تحديث البيانات' %></button>
            </div>
          </form>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h3>إدخالات الأسبوع الحالي</h3>
          <span class="muted"><%= weekLabel %></span>
        </div>
        <div class="panel-body">
          <% if (!recent.length) { %>
            <div class="empty">لا توجد إدخالات بعد.</div>
          <% } else { %>
            <table class="table">
              <thead>
                <tr>
                  <th>التاريخ</th>
                  <% if (department === 'financial') { %>
                    <th>كبار الداعمين</th><th>ديسق</th><th>الكشك</th><th>الجهات المانحة</th><th>الدعم الحكومي</th><th>الإجمالي</th>
                  <% } else if (department === 'media') { %>
                    <th>التصميم</th><th>العنوان</th>
                  <% } else if (department === 'content') { %>
                    <th>عدد المنشورات</th><th>المنصة</th>
                  <% } else if (department === 'followup') { %>
                    <th>من الجمعية</th><th>للجمعية</th><th>الموقع</th><th>الإجمالي</th>
                  <% } %>
                  <th>الملاحظات</th>
                </tr>
              </thead>
              <tbody>
                <% recent.forEach(function(r) { %>
                  <tr>
                    <td><%= new Date(r.date).toLocaleDateString('ar-SA') %></td>
                    <% if (department === 'financial') {
                         const total = (r.majorDonors||0)+disqRevenue+(r.donationKiosk||0)+(r.grantOrganizations||0)+(r.governmentSupport||0); %>
                      <td><%= (r.majorDonors||0).toLocaleString('ar-SA') %></td>
                      <td><%= disqRevenue.toLocaleString('ar-SA') %></td>
                      <td><%= (r.donationKiosk||0).toLocaleString('ar-SA') %></td>
                      <td><%= (r.grantOrganizations||0).toLocaleString('ar-SA') %></td>
                      <td><%= (r.governmentSupport||0).toLocaleString('ar-SA') %></td>
                      <td><strong><%= total.toLocaleString('ar-SA') %></strong></td>
                    <% } else if (department === 'media') { %>
                      <td>
                        <% if (r.imagePath) { %>
                          <img class="table-thumb" src="<%= r.imagePath %>" alt="<%= r.title %>">
                        <% } else { %>
                          —
                        <% } %>
                      </td>
                      <td><%= r.title || '—' %></td>
                    <% } else if (department === 'content') { %>
                      <td><%= (r.count||0).toLocaleString('ar-SA') %></td>
                      <td><%= r.platform || '—' %></td>
                    <% } else if (department === 'followup') {
                         const total = (r.associationToExternal||0)+(r.externalToAssociation||0)+(r.websiteVisits||0); %>
                      <td><%= (r.associationToExternal||0).toLocaleString('ar-SA') %></td>
                      <td><%= (r.externalToAssociation||0).toLocaleString('ar-SA') %></td>
                      <td><%= (r.websiteVisits||0).toLocaleString('ar-SA') %></td>
                      <td><strong><%= total.toLocaleString('ar-SA') %></strong></td>
                    <% } %>
                    <td class="muted"><%= r.note || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </section>
    </main>
  </div>
  <script src="/js/employee.js"></script>
</body>
</html>
