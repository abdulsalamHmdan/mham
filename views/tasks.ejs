<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <%- include('partials/head') %>
  <script src="/socket.io/socket.io.js" defer></script>
</head>
<body>
  <div class="layout">
    <%- include('partials/sidebar') %>

    <main class="main">
      <header class="page-header">
        <div>
          <h1 class="page-title"><%= isExecutive ? 'متابعة المهام' : 'مهامي' %></h1>
          <p class="page-sub"><%= isExecutive ? 'اطلاع على مهام الموظفين وحالة إنجازها' : 'أضف مهامك اليومية وتابع إنجازها' %></p>
        </div>
      </header>

      <% if (canAssign) { %>
      <section class="panel">
        <div class="panel-head">
          <h3>إسناد مهمة لموظف</h3>
          <span class="muted">سيصل الموظف إشعار فوري بالمهمة</span>
        </div>
        <div class="panel-body">
          <% if (!employees.length) { %>
            <div class="empty">لا يوجد موظفون حاليّون لإسناد المهام إليهم.</div>
          <% } else { %>
          <form method="POST" action="/tasks" class="form-grid">
            <label class="field field-full">
              <span>اسم المهمة</span>
              <input type="text" name="title" required placeholder="مثال: تجهيز تقرير الإيرادات الشهري">
            </label>
            <label class="field">
              <span>الموظف المُسند إليه</span>
              <select name="owner" required>
                <option value="">— اختر موظفاً —</option>
                <% employees.forEach(function(emp) { %>
                  <option value="<%= emp._id %>"><%= emp.name %><% if (emp.department) { %> — <%= emp.department %><% } %></option>
                <% }) %>
              </select>
            </label>
            <label class="field">
              <span>تاريخ النهاية</span>
              <input type="date" name="dueDate" required value="<%= new Date(Date.now()+86400000).toISOString().slice(0,10) %>">
            </label>
            <label class="field field-full">
              <span>وصف (اختياري)</span>
              <textarea name="description" rows="2" placeholder="تفاصيل المهمة للموظف"></textarea>
            </label>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">إسناد المهمة</button>
            </div>
          </form>
          <% } %>
        </div>
      </section>
      <% } else { %>
      <section class="panel">
        <div class="panel-head">
          <h3>إضافة مهمة جديدة</h3>
        </div>
        <div class="panel-body">
          <form method="POST" action="/tasks" class="form-grid">
            <label class="field field-full">
              <span>اسم المهمة</span>
              <input type="text" name="title" required placeholder="مثال: تجهيز تقرير الإيرادات الشهري">
            </label>
            <label class="field">
              <span>تاريخ النهاية</span>
              <input type="date" name="dueDate" required value="<%= new Date(Date.now()+86400000).toISOString().slice(0,10) %>">
            </label>
            <label class="field field-full">
              <span>وصف (اختياري)</span>
              <textarea name="description" rows="2"></textarea>
            </label>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">إضافة المهمة</button>
            </div>
          </form>
        </div>
      </section>
      <% } %>

      <section class="panel">
        <div class="panel-head">
          <h3><%= isExecutive ? 'مهام الموظفين' : 'قائمة المهام' %></h3>
          <span class="muted"><%= tasks.filter(t=>t.status==='done').length %> منجزة من <%= tasks.length %></span>
        </div>
        <div class="panel-body">
          <% if (!tasks.length) { %>
            <div class="empty"><%= isExecutive ? 'لا توجد مهام للموظفين بعد.' : 'لا توجد مهام بعد. ابدأ بإضافة مهمة جديدة.' %></div>
          <% } else { %>
            <ul class="task-list">
              <% tasks.forEach(function(t) {
                   const isDone = t.status === 'done';
                   const due = new Date(t.dueDate);
                   const isLate = !isDone && due < new Date(new Date().setHours(0,0,0,0));
              %>
                <li class="task-item <%= isExecutive && !t.owner ? 'is-readonly' : '' %> <%= isDone ? 'is-done' : '' %> <%= isLate ? 'is-late' : '' %>" data-id="<%= t._id %>">
                  <% if (isExecutive) { %>
                  <span class="task-check task-check-readonly" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  <% } else { %>
                  <button class="task-check" data-toggle aria-label="تبديل الحالة">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  </button>
                  <% } %>
                  <div class="task-body">
                    <div class="task-title"><%= t.title %></div>
                    <% if (t.description) { %><div class="task-desc"><%= t.description %></div><% } %>
                    <div class="task-meta">
                      <% if (isExecutive && t.owner) { %>
                        <span class="task-owner">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M20 21a8 8 0 10-16 0"/><circle cx="12" cy="7" r="4"/></svg>
                          <%= t.owner.name %>
                        </span>
                      <% } %>
                      <% if (t.assignedBy && t.assignedBy.name) { %>
                        <span class="task-assigned-by" title="مُسندة من المدير">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                          من: <%= t.assignedBy.name %>
                        </span>
                      <% } %>
                      <span class="task-due">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <%= due.toLocaleDateString('ar-SA') %>
                      </span>
                      <% if (isDone && t.completedAt) { %>
                        <span class="task-done-at">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                          أُتمت <%= new Date(t.completedAt).toLocaleString('ar-SA') %>
                        </span>
                      <% } else if (isLate) { %>
                        <span class="task-late">متأخرة</span>
                      <% } else { %>
                        <span class="task-pending">قيد التنفيذ</span>
                      <% } %>
                    </div>
                  </div>
                  <% if (!isExecutive) { %>
                  <form method="POST" action="/tasks/<%= t._id %>/delete" class="task-delete">
                    <button type="submit" aria-label="حذف" title="حذف">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 01-2 2H9a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                    </button>
                  </form>
                  <% } else if (t.owner) { %>
                  <button type="button" class="task-notify-btn"
                          data-notify="<%= t._id %>"
                          data-owner-name="<%= t.owner.name %>"
                          data-task-title="<%= t.title %>"
                          aria-label="إرسال إشعار لصاحب المهمة"
                          title="إرسال إشعار لصاحب المهمة">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 10-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                    <span>إشعار</span>
                  </button>
                  <% } %>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </section>
    </main>
  </div>

  <% if (isExecutive) { %>
  <div class="modal" id="taskNotifyModal" hidden>
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card">
      <div class="modal-head">
        <h3>إرسال إشعار لصاحب المهمة</h3>
        <button class="modal-close" type="button" data-close aria-label="إغلاق">×</button>
      </div>
      <form id="taskNotifyForm" class="form-grid">
        <div class="task-notify-target muted" id="taskNotifyTarget"></div>
        <label class="field field-full">
          <span>العنوان</span>
          <input type="text" name="title" required maxlength="120" placeholder="مثال: يرجى المتابعة على المهمة">
        </label>
        <label class="field field-full">
          <span>التفاصيل (اختياري)</span>
          <textarea name="body" rows="3" maxlength="600" placeholder="رسالة مختصرة للموظف"></textarea>
        </label>
        <div class="form-actions">
          <button type="button" class="btn btn-ghost" data-close>إلغاء</button>
          <button type="submit" class="btn btn-primary" id="taskNotifySubmit">إرسال الإشعار</button>
        </div>
        <div class="form-status" id="taskNotifyStatus" hidden></div>
      </form>
    </div>
  </div>
  <% } %>

  <script src="/js/tasks.js"></script>
</body>
</html>
